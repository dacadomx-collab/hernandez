# =============================================================================
# PROYECTO  : [NOMBRE_DEL_PROYECTO]
# ARCHIVO   : .htaccess (Raíz)
# PROPÓSITO : Blindaje Nivel Militar — AXON_DCD Security Standard v2
# =============================================================================

# ── PASO 1: APERTURA DE ACCESO (anula restricción 403 heredada del padre cPanel) ─
<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
</IfModule>
Satisfy Any

# ── NIVEL 0: SEGURIDAD GLOBAL ─────────────────────────────────────────────────
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>
DirectoryIndex index.php index.html
ServerSignature Off

# Forzar HTTPS — desactivar en entorno local (XAMPP sin certificado).
# En producción (APP_ENV=production) este bloque debe estar activo siempre.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── NIVEL 1: BLOQUEO DE ARCHIVOS CRÍTICOS ────────────────────────────────────
# Material criptográfico
<FilesMatch "(?i)^(id_rsa|id_rsa\.pub|.*\.pem|.*\.ppk|.*\.key|.*\.crt|.*\.cer)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Archivos de configuración, secretos, pipelines y bases de datos
<FilesMatch "(?i)\.(env|sql|log|bak|ini|yml|yaml|lock|phar|sh|bash)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Dotfiles (.env, .gitignore, .htaccess — bloquea acceso HTTP al archivo en sí)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Archivos de reconocimiento de servidor (WP-Hunter, info de versiones)
<FilesMatch "^(phpinfo\.php|xmlrpc\.php|readme\.html|README\.md|CHANGELOG\.md|composer\.json|composer\.lock|package\.json|package-lock\.json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ── NIVEL 2: CABECERAS DE SEGURIDAD HTTP ──────────────────────────────────────
<IfModule mod_headers.c>
    # Previene Clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Fuerza HTTPS (HSTS) — activar solo si el sitio tiene SSL válido
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Deshabilita la adivinación de tipos MIME
    Header always set X-Content-Type-Options "nosniff"

    # Filtro XSS transversal (legado, CSP es la defensa principal)
    Header always set X-XSS-Protection "1; mode=block"

    # Política de referencia — no filtra origen en mismo sitio, oculta a externos
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Política de permisos (deshabilita APIs sensibles del navegador por defecto)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Content Security Policy — ajustar según CDNs y APIs externas del proyecto
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' https:; connect-src 'self' https:; frame-ancestors 'self';"

    # Ocultar firma del servidor
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── NIVEL 3: BLOQUEO PERIMETRAL DE CARPETAS INTERNAS ─────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear acceso a carpetas de sistema y herramientas de desarrollo
    RewriteRule (^|/)\.git(/|$)              - [F,L,NC]
    RewriteRule (^|/)\.github(/|$)           - [F,L,NC]
    RewriteRule (^|/)\.claude(/|$)           - [F,L,NC]
    RewriteRule (^|/)knowledge(/|$)          - [F,L,NC]
    RewriteRule (^|/)database(/|$)           - [F,L,NC]
    RewriteRule (^|/)logs(/|$)               - [F,L,NC]
    RewriteRule (^|/)backups(_y_pruebas)?(/|$) - [F,L,NC]
    RewriteRule (^|/)tests(/|$)              - [F,L,NC]
    RewriteRule (^|/)vendor(/|$)             - [F,L,NC]
    RewriteRule (^|/)node_modules(/|$)       - [F,L,NC]
    RewriteRule (^|/)scripts(/|$)            - [F,L,NC]
    RewriteRule (^|/)helpers(/|$)             - [F,L,NC]
    RewriteRule (^|/)libs(/|$)                - [F,L,NC]
    RewriteRule (^|/)validators(/|$)          - [F,L,NC]

    # ── NIVEL 4: RUTAS FÍSICAS (assets, api) pasan sin reescritura ────────────
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── NIVEL 5: FRONT CONTROLLER — todo lo demás a index.php ─────────────────
    # (Descomentar si el proyecto usa enrutamiento PHP central)
    # RewriteRule ^ index.php [L,QSA]
</IfModule>

# ── NIVEL 6: COMPRESIÓN GZIP (performance) ───────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/x-javascript text/javascript
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── NIVEL 7: CACHÉ DE ACTIVOS ESTÁTICOS ──────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css   "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# ── PÁGINAS DE ERROR PERSONALIZADAS ───────────────────────────────────────────
ErrorDocument 400 "Solicitud inválida."
ErrorDocument 401 "Autenticación requerida."
ErrorDocument 403 "Acceso denegado."
ErrorDocument 404 "Recurso no encontrado."
ErrorDocument 500 "Error interno del servidor."
